# Model provider key(s) — only the one matching MODEL_PROVIDER is required
OLLAMA_API_KEY=your-ollama-cloud-api-key
# OPENAI_API_KEY=your-openai-api-key

# Primary model provider. One of: ollama, openai, google.
# Used to pick the default model when AGENT_MODEL is empty.
MODEL_PROVIDER=ollama

# Exact model id. Takes precedence over MODEL_PROVIDER when set.
# Format: provider/model-name (e.g. ollama-cloud/gpt-oss:120b, openai/gpt-4.1, google/gemini-2.5-flash)
# Leave empty to use the MODEL_PROVIDER default.
AGENT_MODEL=

# Required for the Drizzle business-data layer
DATABASE_URL=postgres://user:pass@localhost:5432/delivery_copilot

# Shared secret required by custom project-document API routes.
# Frontends must send this as the x-delivery-copilot-token header.
PROJECT_DOCUMENT_API_TOKEN=change-me-in-production

# Which adapter Mastra uses for its own internal state.
# postgres (default, prod): shares pool with Drizzle via PostgresStore.
# libsql (dev): Mastra uses ./mastra.db; Drizzle still uses DATABASE_URL.
MASTRA_STORAGE_DRIVER=postgres

# Only used when MASTRA_STORAGE_DRIVER=libsql
# LIBSQL_URL=file:./mastra.db

# Which adapter the Mastra workspace filesystem uses for agent artifacts.
# local (default): writes to WORKSPACE_BASE_PATH on local disk.
# s3 | gcs | azure: stub — requires installing @mastra/<driver> first.
MASTRA_FILESYSTEM_DRIVER=local
WORKSPACE_BASE_PATH=./workspace

# Retrieval-augmented generation for project documents.
# RAG is opt-in so local workflow demos do not require embedding credentials.
RAG_ENABLED=false
RAG_VECTOR_INDEX=project_document_vectors
RAG_EMBEDDING_DRIVER=mastra
# Example hosted OpenAI embedding setup, no local Ollama required:
# OPENAI_API_KEY=your-openai-api-key
# RAG_ENABLED=true
# RAG_EMBEDDING_DRIVER=langchain-openai
# RAG_EMBEDDING_MODEL=openai/text-embedding-3-small
# RAG_EMBEDDING_DIMENSION=1536
#
# Optional OpenAI-compatible endpoint, for example local Ollama:
# RAG_EMBEDDING_BASE_URL=http://localhost:11434/v1
# RAG_EMBEDDING_API_KEY=optional-endpoint-key
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=6
RAG_MIN_SCORE=0.2

# Frontend app origin allowed to call custom Mastra API routes
FRONTEND_ORIGIN=http://localhost:3000
