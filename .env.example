# Model provider key(s)
OPENAI_API_KEY=your-api-key

# Required for the Drizzle business-data layer
DATABASE_URL=postgres://user:pass@localhost:5432/delivery_copilot

# Which adapter Mastra uses for its own internal state.
# postgres (default, prod): shares pool with Drizzle via PostgresStore.
# libsql (dev): Mastra uses ./mastra.db; Drizzle still uses DATABASE_URL.
MASTRA_STORAGE_DRIVER=postgres

# Only used when MASTRA_STORAGE_DRIVER=libsql
# LIBSQL_URL=file:./mastra.db

# Which adapter the Mastra workspace filesystem uses for agent artifacts.
# local (default): writes to WORKSPACE_BASE_PATH on local disk.
# s3 | gcs | azure: stub — requires installing @mastra/<driver> first.
MASTRA_FILESYSTEM_DRIVER=local
WORKSPACE_BASE_PATH=./workspace

# Retrieval-augmented generation for project documents
RAG_ENABLED=true
RAG_VECTOR_INDEX=project_documents
RAG_EMBEDDING_MODEL=openai/text-embedding-3-small
RAG_EMBEDDING_DIMENSION=1536
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=6
RAG_MIN_SCORE=0.55

# Frontend app origin allowed to call custom Mastra API routes
FRONTEND_ORIGIN=http://localhost:3000
